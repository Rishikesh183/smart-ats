# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: "anthropic" | "openrouter"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter fallback (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku

# Claude model for scoring (full model) and fast ops (haiku)
CLAUDE_SCORING_MODEL=claude-3-5-sonnet-20241022
CLAUDE_FAST_MODEL=claude-3-haiku-20240307

# ── Embeddings ────────────────────────────────────────────────────────────────
# Provider: "local" (sentence-transformers, free, ~3-5s cold load)
#         | "openai" (text-embedding-3-small, instant, ~$0.005/full run, cached)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2        # used when EMBEDDING_PROVIDER=local

# Used when EMBEDDING_PROVIDER=openai:
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=                         # leave blank for OpenAI; set for Azure/Together/etc.

# ── Data ─────────────────────────────────────────────────────────────────────
# Path to candidate CSV/JSON (relative to backend/)
DATASET_PATH=data/candidates.csv

# ── Redis (optional caching) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ── Pipeline knobs ───────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=50
ADVANCE_PERCENTILE_NORMAL=0.60
ADVANCE_PERCENTILE_HIGH=0.60
ADVANCE_PERCENTILE_EXTRA_HIGH=0.60
RESCUE_FLOOR_NORMAL=0.80
RESCUE_FLOOR_HIGH=0.90
RESCUE_FLOOR_EXTRA_HIGH=0.95
FINALIST_COUNT_NORMAL=15
FINALIST_COUNT_EXTRA_HIGH=25
LLM_TEMPERATURE=0.1

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
